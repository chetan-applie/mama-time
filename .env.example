# -----------------------------------------------------------------------------
# MAMA TIME – React + Node + PostgreSQL production configuration
# Copy this file to .env, or run: npm run setup
# Never commit the real .env file.
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_VERSION=2.1.0
PORT=3000
TRUST_PROXY=0
APP_BASE_URL=http://localhost:3000
FRONTEND_DEV_ORIGIN=http://localhost:5173

# PostgreSQL database used by the Node API.
# Local npm development uses 127.0.0.1. Docker Compose overrides the hostname to "db".
DATABASE_URL="postgresql://neondb_owner:npg_Jklfd2vD5xHz@ep-jolly-dust-au60anav-pooler.c-10.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_URL_DOCKER=postgresql://mama_time:mama_time_dev_password@db:5432/mama_time
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000
RUN_MIGRATIONS_ON_START=true
DATABASE_LOG_QUERIES=false
DATABASE_USE_PGMEM=false

# Docker Compose creates the PostgreSQL service with these values.
POSTGRES_DB=mama_time
POSTGRES_USER=mama_time
POSTGRES_PASSWORD=mama_time_dev_password

# Change all secrets before production. `npm run setup` generates them.
JWT_SECRET=replace-with-at-least-48-random-characters
IP_HASH_SECRET=replace-with-at-least-48-random-characters
ADMIN_COOKIE_NAME=mt_admin_token
ADMIN_TOKEN_HOURS=8

# Bootstrap account. It is only created if the admins table is empty.
ADMIN_BOOTSTRAP_EMAIL=admin@sentinators.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe-Now-2026!
ADMIN_BOOTSTRAP_NAME=Sentinators Admin
SHOW_DEFAULT_PASSWORD_WARNING=true

# Campaign defaults. Admin settings in PostgreSQL override these after first start.
CAMPAIGN_ENFORCE=false
CAMPAIGN_START=2026-07-20T00:00:00+02:00
CAMPAIGN_END=2026-08-20T23:59:59+02:00
CAMPAIGN_TIMEZONE=Europe/Zurich
SINGLE_PRICE_CHF=550
BESTIES_PRICE_CHF=990
DAYTIME_HOURS=Montag bis Freitag, 08:00–16:30 Uhr

# Public contact configuration.
WHATSAPP_NUMBER=
WHATSAPP_MESSAGE=Hallo Sentinators Gym, ich interessiere mich für die MAMA TIME Aktion.
NOTIFICATION_EMAIL=

# Meta Pixel defaults. After first start, the backoffice values are authoritative.
# The external Meta script is loaded only after explicit marketing consent.
META_PIXEL_ENABLED=false
META_PIXEL_ID=

# SMTP is optional. Leads are always stored in PostgreSQL and visible in the backoffice.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Sentinator GmbH <info@sentinator.li>

# Public form protection.
PUBLIC_RATE_LIMIT_WINDOW_MINUTES=15
PUBLIC_RATE_LIMIT_MAX=8
PUBLIC_MIN_FORM_SECONDS=2
DUPLICATE_WINDOW_HOURS=24

# Destructive maintenance safeguards. Leave false during normal operation.
ALLOW_DESTRUCTIVE_RESET=false
ALLOW_DESTRUCTIVE_RESTORE=false
ALLOW_JSON_IMPORT=false
