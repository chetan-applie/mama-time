# Sentinators production-domain example. Verify certificate paths on the target server.
server {
    listen 80;
    listen [::]:80;
    server_name sentinators.ch www.sentinators.ch;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name sentinators.ch www.sentinators.ch;

    ssl_certificate     /etc/letsencrypt/live/sentinators.ch/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sentinators.ch/privkey.pem;

    client_max_body_size 1m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    location ~* ^/(backend|tools|docs|reference|node_modules)/ {
        return 404;
    }
}
