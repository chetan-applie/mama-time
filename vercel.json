{
  "version": 2,
  "buildCommand": "npm run db:migrate && npm run build && npm run doctor && npm run test",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api).*)*",
      "destination": "/index.html"
    }
  ]
}